rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isBitsEmail() {
      return request.auth != null &&
             request.auth.token.email.matches('.*@(hyderabad|pilani|goa|dubai)[.]bits-pilani[.]ac[.]in$');
    }

    function isOwner(userId) {
      let email = request.auth.token.email;
      let username = email.split('@')[0];
      return request.auth != null && (
        userId == username + 'H' && email.matches('.*@hyderabad[.]bits-pilani[.]ac[.]in$') ||
        userId == username + 'P' && email.matches('.*@pilani[.]bits-pilani[.]ac[.]in$') ||
        userId == username + 'G' && email.matches('.*@goa[.]bits-pilani[.]ac[.]in$') ||
        userId == username + 'D' && email.matches('.*@dubai[.]bits-pilani[.]ac[.]in$')
      );
    }

    // Admins are identified by email via the `admin_emails` collection
    // (doc id = lowercased email). exists() inside rules is a privileged read,
    // so admin_emails can stay non-client-readable below.
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email != null &&
             exists(/databases/$(database)/documents/admin_emails/$(request.auth.token.email.lower()));
    }

    function userDocId() {
      let email = request.auth.token.email;
      let username = email.split('@')[0];
      let suffix = email.matches('.*@hyderabad[.]bits-pilani[.]ac[.]in$') ? 'H' :
                   email.matches('.*@pilani[.]bits-pilani[.]ac[.]in$') ? 'P' :
                   email.matches('.*@goa[.]bits-pilani[.]ac[.]in$') ? 'G' : 'D';
      return username + suffix;
    }

    // ── Kill switch ────────────────────────────────────────────────────────
    // Flip `maintenance` to true on reference/app_config (Firestore console) to
    // freeze all access below except admins and the reference docs themselves
    // (so clients can still read the "down" message). Fail-open: if the config
    // doc is missing, the app stays available.
    function maintenanceOn() {
      return exists(/databases/$(database)/documents/reference/app_config)
        && get(/databases/$(database)/documents/reference/app_config).data.get('maintenance', false) == true;
    }
    function appAvailable() {
      return !maintenanceOn() || isAdmin();
    }

    // Campus data (courses_master, timetable, exam_seating, metadata)
    match /campuses/{campusId}/{sub=**} {
      allow read: if appAvailable();
      allow write: if isAdmin();
    }

    // Reference data (professors, app_config, etc.)
    // Reads stay open so clients can fetch the kill-switch message while down.
    match /reference/{category}/{sub=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User data — owner only
    match /users/{userId}/{sub=**} {
      allow read, write: if isOwner(userId) && appAvailable();
    }

    // Announcements — reads by BITS users; create/delete by author; updates only via Cloud Functions
    match /announcements/{announcementId} {
      allow read: if isBitsEmail() && appAvailable();
      allow create: if isBitsEmail() && appAvailable()
        && request.resource.data.authorUid == userDocId()
        && request.resource.data.upvotes == 0
        && request.resource.data.downvotes == 0
        && request.resource.data.disputeState == 'undisputed'
        && request.resource.data.totalFlagWeight == 0
        && request.resource.data.verificationState == 'unverified'
        && request.resource.data.confirmWeight == 0
        && request.resource.data.denyWeight == 0
        && request.resource.data.confirmCount == 0
        && request.resource.data.denyCount == 0
        // Content bounds: the counters above were validated but the free-text
        // fields were not, so any signed-in user could write ~1MB documents.
        // Nullable fields (source.url/referenceId) must tolerate null.
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 2000
        && request.resource.data.courseCode is string
        && request.resource.data.courseCode.size() <= 50
        && request.resource.data.sectionId is string
        && request.resource.data.sectionId.size() <= 30
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() <= 120
        && request.resource.data.confidence is string
        && request.resource.data.confidence.size() <= 40
        && (request.resource.data.source.url == null
            || request.resource.data.source.url.size() <= 500)
        && (request.resource.data.source.referenceId == null
            || request.resource.data.source.referenceId.size() <= 200);
      allow delete: if isBitsEmail() && appAvailable()
        && resource.data.authorUid == userDocId();
      allow update: if false;

      match /votes/{visitorUid} {
        allow read: if isBitsEmail() && appAvailable();
        allow write: if false;
      }
      match /flags/{flagUid} {
        allow read: if isBitsEmail() && appAvailable();
        allow write: if false;
      }
      match /verifications/{verifUid} {
        allow read: if isBitsEmail() && appAvailable();
        allow write: if false;
      }
    }

    // Collection-group reads so a user can fetch their OWN vote/flag/verification
    // across all announcements in one query each (see fetchUserStates). Without
    // these, that lookup costs 3 point reads per announcement. Scoped to the
    // caller's own documents; writes still only via Cloud Functions.
    match /{path=**}/votes/{voteId} {
      allow read: if isBitsEmail() && appAvailable() && voteId == userDocId();
      allow write: if false;
    }
    match /{path=**}/flags/{flagId} {
      allow read: if isBitsEmail() && appAvailable() && flagId == userDocId();
      allow write: if false;
    }
    match /{path=**}/verifications/{verifId} {
      allow read: if isBitsEmail() && appAvailable() && verifId == userDocId();
      allow write: if false;
    }

    // Reputation — reads by BITS users; writes only via Cloud Functions (Admin SDK)
    match /reputation/{uid} {
      allow read: if isBitsEmail() && appAvailable();
      allow write: if false;
    }

    // Academic drives — three top-level collections
    match /acad_drives_files/{docId} {
      allow read: if appAvailable();
      allow write: if false;
    }
    match /acad_drives_submissions/{docId} {
      // Schema mirrors the client payload (acad_drives_screen.dart): driveLink,
      // title, contributorName, submittedBy, status, submittedAt. driveLink must
      // be an https:// URL; other fields are length-bounded.
      allow create: if isBitsEmail() && appAvailable()
        && request.resource.data.keys().hasOnly(
             ['driveLink', 'title', 'contributorName', 'submittedBy', 'status', 'submittedAt'])
        && request.resource.data.keys().hasAll(
             ['driveLink', 'title', 'contributorName', 'submittedBy', 'status'])
        && request.resource.data.submittedBy == request.auth.token.email
        && request.resource.data.driveLink is string
        && request.resource.data.driveLink.matches('https://.*')
        && request.resource.data.driveLink.size() < 2048
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() < 200
        && request.resource.data.contributorName is string
        && request.resource.data.contributorName.size() < 100
        && request.resource.data.status == 'pending';
      allow read: if appAvailable();
      allow update, delete: if false;
    }
    match /acad_drives_tags/{docId} {
      allow read: if appAvailable();
      allow write: if false;
    }
    match /acad_drives_index/{docId} {
      allow read: if appAvailable();
      allow write: if false;
    }

    // Shared timetables
    match /shared_timetables/{docId} {
      allow read: if isBitsEmail() && appAvailable();
      allow create: if isBitsEmail() && appAvailable()
        && request.resource.data.ownerId == userDocId();
      allow update: if isBitsEmail() && appAvailable()
        && resource.data.ownerId == userDocId()
        && request.resource.data.ownerId == userDocId();
      allow delete: if isBitsEmail() && appAvailable()
        && resource.data.ownerId == userDocId();
    }

    // Minor programmes — reference data from the Bulletin. Readable by anyone
    // using the app (guests included, like the FAQ); only admins can edit.
    match /minors/{minorId} {
      allow read: if appAvailable();
      allow write: if isAdmin() && appAvailable();
    }

    // Bug reports — authors file and read their own; admins read all and can
    // only advance the status. Nothing is deletable from the client.
    match /bug_reports/{reportId} {
      allow read: if appAvailable() && (
        isAdmin() ||
        (request.auth != null && resource.data.authorUid == userDocId())
      );
      allow create: if isBitsEmail() && appAvailable()
        && request.resource.data.authorUid == userDocId()
        && request.resource.data.authorEmail == request.auth.token.email
        && request.resource.data.status == 'pending'
        && request.resource.data.category is string
        && request.resource.data.category.size() > 0
        && request.resource.data.category.size() < 100
        && request.resource.data.subCategory is string
        && request.resource.data.subCategory.size() > 0
        && request.resource.data.subCategory.size() < 100
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.description.size() < 5000;
      // Admins advance status; the author may only stamp their own reply time.
      // Neither side can rewrite the report body once filed.
      allow update: if appAvailable() && (
        (isAdmin()
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status', 'updatedAt', 'lastAdminReplyAt'])
          && request.resource.data.status in ['pending', 'in_review', 'dev_in_progress', 'fixed'])
        ||
        (request.auth != null
          && resource.data.authorUid == userDocId()
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['lastUserReplyAt']))
      );
      allow delete: if false;

      // Conversation thread. Only the report's author and admins can read or
      // post, and `isAdmin` on a message must match the writer's real role —
      // that is what lets the UI trust it for attribution.
      match /messages/{messageId} {
        function report() {
          return get(/databases/$(database)/documents/bug_reports/$(reportId)).data;
        }
        function isReporter() {
          return request.auth != null && report().authorUid == userDocId();
        }

        allow read: if appAvailable() && (isAdmin() || isReporter());
        allow create: if appAvailable()
          && request.resource.data.authorUid == userDocId()
          && request.resource.data.isAdmin is bool
          && request.resource.data.body is string
          && request.resource.data.body.size() > 0
          && request.resource.data.body.size() < 5000
          && request.resource.data.createdAt == request.time
          && (
            (isAdmin() && request.resource.data.isAdmin == true)
            || (isReporter() && request.resource.data.isAdmin == false)
          );
        // Threads are an audit trail — nothing is editable or removable.
        allow update, delete: if false;
      }
    }

    // Admin metadata
    match /admin_metadata/{docId} {
      allow read: if appAvailable();
      allow write: if false;
    }

    // Admin allowlist — source of truth for admin access (doc id = lowercased
    // email). Managed via the Firestore console / Admin SDK only; never exposed
    // to clients (isAdmin()'s exists() check bypasses these rules).
    match /admin_emails/{email} {
      allow read, write: if false;
    }

    // Legacy admin_users (no longer used; kept locked down).
    match /admin_users/{userId} {
      allow read: if false;
      allow write: if false;
    }
  }
}
