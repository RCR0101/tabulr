rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isBitsEmail() {
      return request.auth != null &&
             request.auth.token.email.matches('.*@(hyderabad|pilani|goa|dubai)[.]bits-pilani[.]ac[.]in$');
    }

    function isOwner(userId) {
      let email = request.auth.token.email;
      let username = email.split('@')[0];
      return request.auth != null && (
        userId == username + 'H' && email.matches('.*@hyderabad[.]bits-pilani[.]ac[.]in$') ||
        userId == username + 'P' && email.matches('.*@pilani[.]bits-pilani[.]ac[.]in$') ||
        userId == username + 'G' && email.matches('.*@goa[.]bits-pilani[.]ac[.]in$') ||
        userId == username + 'D' && email.matches('.*@dubai[.]bits-pilani[.]ac[.]in$')
      );
    }

    function userDocId() {
      let email = request.auth.token.email;
      let username = email.split('@')[0];
      let suffix = email.matches('.*@hyderabad[.]bits-pilani[.]ac[.]in$') ? 'H' :
                   email.matches('.*@pilani[.]bits-pilani[.]ac[.]in$') ? 'P' :
                   email.matches('.*@goa[.]bits-pilani[.]ac[.]in$') ? 'G' : 'D';
      return username + suffix;
    }

    // Campus data (courses_master, timetable, exam_seating, metadata)
    match /campuses/{campusId}/{sub=**} {
      allow read: if true;
      allow write: if false;
    }

    // Reference data
    match /reference/{category}/{sub=**} {
      allow read: if true;
      allow write: if false;
    }

    // User data — owner only
    match /users/{userId}/{sub=**} {
      allow read, write: if isOwner(userId);
    }

    // Announcements
    match /announcements/{announcementId} {
      allow read: if isBitsEmail();
      allow create: if isBitsEmail()
        && request.resource.data.authorUid == userDocId();
      allow delete: if isBitsEmail()
        && resource.data.authorUid == userDocId();
      allow update: if isBitsEmail()
        && request.resource.data.authorUid == resource.data.authorUid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['upvotes', 'downvotes', 'totalFlagWeight', 'topFlagReason',
                      'topFlagCounterSource', 'disputeState', 'correctionText',
                      'correctionSource', 'confirmWeight', 'denyWeight',
                      'confirmCount', 'denyCount', 'verificationState']);

      match /votes/{visitorUid} {
        allow read: if isBitsEmail();
        allow write: if isBitsEmail() && visitorUid == userDocId();
      }
      match /flags/{flagUid} {
        allow read: if isBitsEmail();
        allow write: if isBitsEmail() && flagUid == userDocId();
      }
      match /verifications/{verifUid} {
        allow read: if isBitsEmail();
        allow write: if isBitsEmail() && verifUid == userDocId();
      }
    }

    // Reputation
    match /reputation/{uid} {
      allow read: if isBitsEmail();
      allow create: if isBitsEmail();
      allow update: if isBitsEmail()
        && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['score', 'lastActive', 'events', 'suspendedUntil']);
    }

    // Academic drives — three top-level collections
    match /acad_drives_files/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /acad_drives_submissions/{docId} {
      allow create: if request.auth != null;
      allow read: if true;
      allow update, delete: if false;
    }
    match /acad_drives_tags/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /acad_drives_index/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Admin metadata
    match /admin_metadata/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
